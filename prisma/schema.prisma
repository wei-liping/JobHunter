// JobHunter AI — PostgreSQL via Prisma

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum JobPlatform {
  BOSS     @map("boss")
  LIEPIN   @map("liepin")
  JOB51    @map("job51")
  ZHILIAN  @map("zhilian")
  MANUAL   @map("manual")
}

enum ResumeSourceType {
  MANUAL    @map("manual")
  IMPORTED  @map("imported")
  OCR       @map("ocr")
  TAILORED  @map("tailored")
}

enum ApplicationStatus {
  NEW              @map("new")
  SCORED_HIGH      @map("scored_high")
  SCORED_LOW       @map("scored_low")
  REVIEWED         @map("reviewed")
  READY_TO_APPLY   @map("ready_to_apply")
}

model Job {
  id            String      @id @default(cuid())
  title         String
  company       String
  salary        String?
  jdText        String      @db.Text
  requirements  String[]    @default([])
  url           String?
  platform      JobPlatform @default(MANUAL)
  companyInfo   Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  applications     Application[]
  savedJob         SavedJob?
  sourcedResumes   Resume[]          @relation("ResumeSourceJob")
  interviewSessions InterviewSession[]
}

model Resume {
  id           String   @id @default(cuid())
  title        String   @default("我的简历")
  rawMarkdown  String   @db.Text
  filePath     String?
  sourceType   ResumeSourceType @default(MANUAL)
  sourceLabel  String?
  sourceJobId  String?
  sourceJob    Job?     @relation("ResumeSourceJob", fields: [sourceJobId], references: [id], onDelete: SetNull)
  parentResumeId String?
  parentResume Resume?  @relation("ResumeVersionLineage", fields: [parentResumeId], references: [id], onDelete: SetNull)
  childResumes Resume[] @relation("ResumeVersionLineage")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  applications      Application[]
  interviewSessions InterviewSession[]
}

model Application {
  id                 String            @id @default(cuid())
  jobId              String
  job                Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resumeId           String
  resume             Resume            @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  status             ApplicationStatus @default(NEW)
  tailoredResumeJson String?           @db.Text
  coverLetter        String?           @db.Text
  reviewNotes        String?           @db.Text
  reviewSummary      String?           @db.Text
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  scores Score[]

  @@unique([jobId, resumeId])
}

model Score {
  id              String        @id @default(cuid())
  applicationId   String
  application     Application   @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  matchScore      Int
  analysisJson    Json
  model           String?
  createdAt       DateTime      @default(now())
}

model SavedJob {
  id         String   @id @default(cuid())
  jobId       String   @unique
  note       String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model InterviewSession {
  id         String   @id @default(cuid())
  title      String?
  jobId      String
  resumeId   String
  summary    String?  @db.Text
  transcript Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  job    Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
}
