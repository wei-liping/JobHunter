# Copy to .env and adjust

# --- 在线演示模式（Vercel 等无数据库部署）---
# 同时设置以下两项；岗位数据来自 public/data/jobs-ai-pm.json，访客数据仅存浏览器。
# DEMO_MODE=1
# NEXT_PUBLIC_DEMO_MODE=1

# Local Postgres (docker-compose)
DATABASE_URL="postgresql://jobhunter:jobhunter@localhost:5432/jobhunter?schema=public"

# OpenAI-compatible API (OpenAI, DeepSeek, etc.)
OPENAI_API_KEY=""
# Optional: DeepSeek — https://api.deepseek.com/v1
# OPENAI_BASE_URL="https://api.deepseek.com/v1"
OPENAI_MODEL="gpt-4o-mini"
ALLOWED_AI_BASE_URLS="https://api.openai.com/v1,https://api.deepseek.com/v1,https://ark.cn-beijing.volces.com/api/v3"

# Optional admin token gate for /api/ai/ping and Feishu integration routes
JOBHUNTER_ADMIN_TOKEN=""

# Local DrissionPage crawl: allow POST /api/crawl/local when not in development (default off)
# JOBHUNTER_ALLOW_LOCAL_CRAWL=1
# Optional: override Python for crawl (default tools/boss_zhipin_crawl/.venv/bin/python)
# JOBHUNTER_CRAWL_PYTHON="/path/to/python"
#
# Crawl pacing (passed to crawl_boss.py; optional query/body overrides these)
# Defaults: list 10s, detail 1s, DOM wait 7s, listen timeout 35s
# JOBHUNTER_CRAWL_LIST_SLEEP=10
# JOBHUNTER_CRAWL_DETAIL_SLEEP=1
# JOBHUNTER_CRAWL_DETAIL_DOM_WAIT=7
# JOBHUNTER_CRAWL_DETAIL_LISTEN_TIMEOUT=35

# Feishu sync layer (optional, not the primary datastore)
FEISHU_BASE_URL="https://open.feishu.cn"
FEISHU_APP_ID=""
FEISHU_APP_SECRET=""
FEISHU_BITABLE_APP_TOKEN=""
FEISHU_BITABLE_TABLE_ID=""
FEISHU_BOT_WEBHOOK=""

# Local file uploads (relative to project root)
UPLOAD_DIR="uploads"
